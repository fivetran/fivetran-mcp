{
  "description": "⚠️ RESULTS ARE PAGINATED. The endpoint allows you to retrieve the list of existing webhooks available for the current account",
  "path": "/v1/webhooks",
  "method": "GET",
  "parameters": [
    {
      "name": "cursor",
      "in": "query",
      "required": false,
      "description": "Paging cursor, [read more about pagination](https://fivetran.com/docs/rest-api/pagination)",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "description": "Number of records to fetch per page. Accepts a number in the range 1..1000; the default value is 100.",
      "schema": {
        "type": "integer",
        "format": "int32"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "description": "The collection of returned items",
                "items": {
                  "required": [
                    "active",
                    "created_at",
                    "created_by",
                    "events",
                    "id",
                    "type",
                    "url"
                  ],
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Unique identifier for the webhook."
                    },
                    "type": {
                      "type": "string",
                      "description": "The type of the webhook. Specifies whether the webhook is associated with a group or an account.",
                      "enum": [
                        "group",
                        "account"
                      ]
                    },
                    "url": {
                      "type": "string",
                      "description": "The endpoint URL where webhook events will be delivered."
                    },
                    "events": {
                      "type": "array",
                      "description": "List of event types that trigger the webhook.",
                      "items": {
                        "type": "string"
                      }
                    },
                    "active": {
                      "type": "boolean",
                      "description": "Indicates if the webhook is enabled to send events immediately upon occurrence."
                    },
                    "secret": {
                      "type": "string",
                      "description": "A secret string used to sign webhook payloads for verification."
                    },
                    "group_id": {
                      "type": "string",
                      "description": "Unique identifier for the group associated with the webhook."
                    },
                    "created_at": {
                      "type": "string",
                      "description": "Timestamp indicating when the webhook was created.",
                      "format": "date-time"
                    },
                    "created_by": {
                      "type": "string",
                      "description": "Identifier of the user who created the webhook setting."
                    }
                  }
                }
              },
              "next_cursor": {
                "type": "string",
                "description": "The value of the cursor parameter for the next page"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}