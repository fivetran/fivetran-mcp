{
  "description": "⚠️ WRITE OPERATION - Confirm with user before calling. Updates user group membership.",
  "path": "/v1/users/{userId}/groups/{groupId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "userId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the user within the account.",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "groupId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the group within the Fivetran system.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "request_body": {
    "content": {
      "application/json": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "The role that you would like to assign to the user "
          }
        }
      }
    }
  },
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          }
        }
      }
    },
    "description": "Successful response"
  }
}