{
  "description": "⚠️ RESULTS ARE PAGINATED. Returns a list of users and their roles within a team in your Fivetran account",
  "path": "/v1/teams/{teamId}/users",
  "method": "GET",
  "parameters": [
    {
      "name": "teamId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the team within the account.",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "cursor",
      "in": "query",
      "required": false,
      "description": "Paging cursor, [read more about pagination](https://fivetran.com/docs/rest-api/pagination)",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "description": "Number of records to fetch per page. Accepts a number in the range 1..1000; the default value is 100.",
      "schema": {
        "type": "integer",
        "format": "int32"
      }
    },
    {
      "name": "active",
      "in": "query",
      "required": false,
      "description": "Indicates whether to return only enabled users (true) or not (false). By default, both enabled (allowed to log in) and suspended users are returned.",
      "schema": {
        "type": "boolean"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "description": "The collection of returned items",
                "items": {
                  "required": [
                    "created_at",
                    "role",
                    "user_id"
                  ],
                  "type": "object",
                  "properties": {
                    "user_id": {
                      "type": "string",
                      "description": "The unique identifier of user"
                    },
                    "role": {
                      "type": "string",
                      "description": "The user's role within the team"
                    },
                    "created_at": {
                      "type": "string",
                      "description": "The date and time the membership was created",
                      "format": "date-time"
                    }
                  }
                }
              },
              "next_cursor": {
                "type": "string",
                "description": "The value of the cursor parameter for the next page"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}