{
  "description": "⚠️ WRITE OPERATION - Confirm with user before calling. Updates a user membership in a team.",
  "path": "/v1/teams/{teamId}/users/{userId}",
  "method": "PATCH",
  "parameters": [
    {
      "name": "teamId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the team within the account.",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "userId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the user within the account.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "request_body": {
    "content": {
      "application/json": {
        "required": [
          "role"
        ],
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "description": "The user's role within the team"
          }
        }
      }
    }
  },
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "created_at",
              "role",
              "user_id"
            ],
            "type": "object",
            "properties": {
              "user_id": {
                "type": "string",
                "description": "The unique identifier of user"
              },
              "role": {
                "type": "string",
                "description": "The user's role within the team"
              },
              "created_at": {
                "type": "string",
                "description": "The date and time the membership was created",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}