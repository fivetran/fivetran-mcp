{
  "description": "Returns details of a team membership in a group.",
  "path": "/v1/teams/{teamId}/groups/{groupId}",
  "method": "GET",
  "parameters": [
    {
      "name": "teamId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the team within the account.",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "groupId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the group within the Fivetran system.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "created_at",
              "id",
              "role"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The membership entity unique identifier"
              },
              "role": {
                "type": "string",
                "description": "The role the user has within the entity"
              },
              "created_at": {
                "type": "string",
                "description": "The timestamp that the user created their Fivetran account",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}