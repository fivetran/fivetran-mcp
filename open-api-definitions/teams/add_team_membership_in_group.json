{
  "description": "⚠️ WRITE OPERATION - Confirm with user before calling. Adds a team as a member of a group.",
  "path": "/v1/teams/{teamId}/groups",
  "method": "POST",
  "parameters": [
    {
      "name": "teamId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the team within the account.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "request_body": {
    "content": {
      "application/json": {
        "required": [
          "id",
          "role"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The group unique identifier"
          },
          "role": {
            "type": "string",
            "description": "The team's role"
          }
        }
      }
    }
  },
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "created_at",
              "id",
              "role"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The membership entity unique identifier"
              },
              "role": {
                "type": "string",
                "description": "The role the user has within the entity"
              },
              "created_at": {
                "type": "string",
                "description": "The timestamp that the user created their Fivetran account",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}