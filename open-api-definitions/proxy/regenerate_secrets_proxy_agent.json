{
  "description": "⚠️ WRITE OPERATION - Confirm with user before calling. Regenerate secrets for proxy agent within your Fivetran account.",
  "path": "/v1/proxy/{agentId}/regenerate-secrets",
  "method": "POST",
  "parameters": [
    {
      "name": "agentId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the proxy agent within the Fivetran system.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "agent_id",
              "auth_token",
              "client_cert",
              "client_private_key",
              "orchestrator_host",
              "orchestrator_port"
            ],
            "type": "object",
            "properties": {
              "agent_id": {
                "type": "string",
                "description": "The unique identifier for the proxy agent within the Fivetran system."
              },
              "auth_token": {
                "type": "string",
                "description": "The auth token."
              },
              "client_cert": {
                "type": "string",
                "description": "Client certificate."
              },
              "client_private_key": {
                "type": "string",
                "description": "Client private key."
              },
              "orchestrator_host": {
                "type": "string",
                "description": "The hostname that the Proxy Agent uses to connect to the Fivetran orchestrator."
              },
              "orchestrator_port": {
                "type": "integer",
                "description": "The port that the Proxy Agent uses to connect to the Fivetran orchestrator.",
                "format": "int32"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}