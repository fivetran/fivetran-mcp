{
  "description": "Returns details of the certificate approved for the specified connection with specified certificate hash.",
  "path": "/v1/connections/{connectionId}/certificates/{hash}",
  "method": "GET",
  "parameters": [
    {
      "name": "connectionId",
      "in": "path",
      "required": true,
      "description": "The unique identifier of the connection. Retrieve it from the `id` field in the [List All Connections](https://fivetran.com/docs/rest-api/api-reference/connections/list-connections) response, or from the `id` field returned when you [Create a Connection](https://fivetran.com/docs/rest-api/api-reference/connections/create-connection).",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "hash",
      "in": "path",
      "required": true,
      "description": "The unique identifier of the certificate (Base64URL encoded hash of the certificate).",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "hash",
              "id",
              "name",
              "public_key",
              "sha1",
              "sha256",
              "type",
              "validated_by",
              "validated_date"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier of the certificate (Base64URL encoded hash of the certificate)."
              },
              "name": {
                "type": "string",
                "description": "The certificate name."
              },
              "hash": {
                "type": "string",
                "description": "Hash of the certificate."
              },
              "type": {
                "type": "string",
                "description": "Type of the certificate."
              },
              "sha1": {
                "type": "string",
                "description": "SHA1 of certificate."
              },
              "sha256": {
                "type": "string",
                "description": "SHA256 of certificate."
              },
              "public_key": {
                "type": "string",
                "description": "The certificate decoded public key."
              },
              "validated_date": {
                "type": "string",
                "description": "Date when certificate has been validated and approved.",
                "format": "date-time"
              },
              "validated_by": {
                "type": "string",
                "description": "The unique identified for the user who has approved the certificate."
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}