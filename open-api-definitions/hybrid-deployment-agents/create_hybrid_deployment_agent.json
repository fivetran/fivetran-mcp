{
  "description": "⚠️ WRITE OPERATION - Confirm with user before calling. Creates a new Hybrid Deployment Agent in a group.",
  "path": "/v1/hybrid-deployment-agents",
  "method": "POST",
  "request_body": {
    "content": {
      "application/json": {
        "required": [
          "accept_terms",
          "display_name",
          "env_type"
        ],
        "type": "object",
        "properties": {
          "group_id": {
            "type": "string",
            "description": "The unique identifier for the group within your Fivetran account."
          },
          "display_name": {
            "type": "string",
            "description": "Hybrid Deployment Agent display name."
          },
          "env_type": {
            "type": "string",
            "description": "Environment type.",
            "enum": [
              "DOCKER",
              "PODMAN",
              "KUBERNETES",
              "SNOWPARK"
            ]
          },
          "accept_terms": {
            "type": "boolean",
            "description": "Boolean, must be true to indicate that the caller accepts the Fivetran On-Prem Software License Addendum."
          },
          "auth_type": {
            "type": "string",
            "description": "Agent Auth Mode. Defines how agent should be authorised.",
            "enum": [
              "AUTO",
              "MANUAL"
            ]
          }
        }
      }
    }
  },
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "created_by",
              "deployment_type",
              "display_name",
              "enabled",
              "group_id",
              "id",
              "last_used_at",
              "online",
              "registered_at",
              "updated_at",
              "version"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier for the hybrid deployment agent within the Fivetran system."
              },
              "version": {
                "type": "string",
                "description": "Version of the Hybrid Deployment Agent"
              },
              "enabled": {
                "type": "boolean",
                "description": "The boolean value specifying whether the Hybrid Deployment Agent is enabled."
              },
              "online": {
                "type": "boolean",
                "description": "The boolean value specifying whether the Hybrid Deployment Agent is online."
              },
              "files": {
                "required": [
                  "auth_json",
                  "config_json",
                  "docker_compose_yaml"
                ],
                "type": "object",
                "properties": {
                  "config_json": {
                    "type": "string",
                    "description": "Base64 encoded content of the config.json",
                    "format": "byte"
                  },
                  "auth_json": {
                    "type": "string",
                    "description": "Base64 encoded content of the auth.json",
                    "format": "byte"
                  },
                  "docker_compose_yaml": {
                    "type": "string",
                    "description": "Base64 encoded content of the docker-compose.yaml",
                    "format": "byte"
                  }
                }
              },
              "token": {
                "type": "string",
                "description": "Base64 encoded content of token"
              },
              "display_name": {
                "type": "string",
                "description": "Hybrid Deployment Agent display name."
              },
              "group_id": {
                "type": "string",
                "description": "The unique identifier for the group within your Fivetran account."
              },
              "registered_at": {
                "type": "string",
                "description": "Time when this Hybrid Deployment Agent was created.",
                "format": "date-time"
              },
              "created_by": {
                "type": "string",
                "description": "The actor who created the Hybrid Deployment Agent"
              },
              "deployment_type": {
                "type": "string",
                "description": "Environment type.",
                "enum": [
                  "DOCKER",
                  "PODMAN",
                  "KUBERNETES",
                  "SNOWPARK"
                ]
              },
              "updated_at": {
                "type": "string",
                "description": "Time when this Hybrid Deployment Agent was updated.",
                "format": "date-time"
              },
              "last_used_at": {
                "type": "string",
                "description": "The time this Hybrid Deployment Agent was last used.",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}