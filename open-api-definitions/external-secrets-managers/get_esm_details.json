{
  "description": "Returns the details of an existing External Secrets Manager instance.",
  "path": "/v1/external-secrets-managers/{esmId}",
  "method": "GET",
  "parameters": [
    {
      "name": "esmId",
      "in": "path",
      "required": true,
      "description": "The unique identifier of the External Secrets Manager instance.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier of the External Secrets Manager instance."
              },
              "type": {
                "type": "string",
                "description": "The ESM provider type",
                "enum": [
                  "AWS_SECRET_MANAGER",
                  "AZURE_KEY_VAULT",
                  "HASHICORP_VAULT"
                ]
              },
              "name": {
                "type": "string",
                "description": "The name of the ESM instance"
              },
              "config": {
                "type": "object",
                "additionalProperties": {
                  "type": "object"
                },
                "description": "Provider-specific configuration."
              },
              "is_hybrid_deployment": {
                "type": "boolean",
                "description": "Whether this External Secrets Manager instance is compatible with Hybrid Deployment environments."
              },
              "created_at": {
                "type": "string",
                "description": "The timestamp when the ESM instance was created.",
                "format": "date-time"
              },
              "updated_at": {
                "type": "string",
                "description": "The timestamp when the ESM instance was last updated.",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}