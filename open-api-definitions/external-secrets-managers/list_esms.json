{
  "description": "⚠️ RESULTS ARE PAGINATED. Returns a list of all External Secrets Manager instances within your Fivetran account.",
  "path": "/v1/external-secrets-managers",
  "method": "GET",
  "parameters": [
    {
      "name": "cursor",
      "in": "query",
      "required": false,
      "description": "Paging cursor, [read more about pagination](https://fivetran.com/docs/rest-api/pagination)",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "description": "Number of records to fetch per page. Accepts a number in the range 1..1000; the default value is 100.",
      "schema": {
        "type": "integer",
        "format": "int32"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "description": "The collection of returned items",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "The unique identifier of the External Secrets Manager instance."
                    },
                    "type": {
                      "type": "string",
                      "description": "The ESM provider type",
                      "enum": [
                        "AWS_SECRET_MANAGER",
                        "AZURE_KEY_VAULT",
                        "HASHICORP_VAULT"
                      ]
                    },
                    "name": {
                      "type": "string",
                      "description": "The name of the ESM instance"
                    },
                    "config": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object"
                      },
                      "description": "Provider-specific configuration."
                    },
                    "is_hybrid_deployment": {
                      "type": "boolean",
                      "description": "Whether this External Secrets Manager instance is compatible with Hybrid Deployment environments."
                    },
                    "created_at": {
                      "type": "string",
                      "description": "The timestamp when the ESM instance was created.",
                      "format": "date-time"
                    },
                    "updated_at": {
                      "type": "string",
                      "description": "The timestamp when the ESM instance was last updated.",
                      "format": "date-time"
                    }
                  }
                }
              },
              "next_cursor": {
                "type": "string",
                "description": "The value of the cursor parameter for the next page"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}