{
  "description": "⚠️ RESULTS ARE PAGINATED. Returns the list of approved SSH fingerprints for specified destination",
  "path": "/v1/destinations/{destinationId}/fingerprints",
  "method": "GET",
  "parameters": [
    {
      "name": "destinationId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the destination within the Fivetran system.",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "cursor",
      "in": "query",
      "required": false,
      "description": "Paging cursor, [read more about pagination](https://fivetran.com/docs/rest-api/pagination)",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "description": "Number of records to fetch per page. Accepts a number in the range 1..1000; the default value is 100.",
      "schema": {
        "type": "integer",
        "format": "int32"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "description": "The collection of returned items",
                "items": {
                  "required": [
                    "hash",
                    "id",
                    "public_key",
                    "validated_by",
                    "validated_date"
                  ],
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "The unique identifier of the fingerprint (Base64URL encoded hash of the fingerprint)."
                    },
                    "hash": {
                      "type": "string",
                      "description": "Hash of the fingerprint."
                    },
                    "public_key": {
                      "type": "string",
                      "description": "The SSH public key."
                    },
                    "validated_date": {
                      "type": "string",
                      "description": "Date when fingerprint has been validated and approved.",
                      "format": "date-time"
                    },
                    "validated_by": {
                      "type": "string",
                      "description": "The unique identified for the user who has approved the fingerprint."
                    }
                  }
                }
              },
              "next_cursor": {
                "type": "string",
                "description": "The value of the cursor parameter for the next page"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}