{
  "description": "⚠️ WRITE OPERATION - Confirm with user before calling. Cancels the execution of the transformation if a valid identifier is provided.",
  "path": "/v1/transformations/{transformationId}/cancel",
  "method": "POST",
  "parameters": [
    {
      "name": "transformationId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the transformation within the Fivetran system",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          }
        }
      }
    },
    "description": "Successful response"
  }
}