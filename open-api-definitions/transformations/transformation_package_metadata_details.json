{
  "description": "Returns the metadata details of the Quickstart transformation package if a valid identifier is provided.",
  "path": "/v1/transformations/package-metadata/{package_definition_id}",
  "method": "GET",
  "parameters": [
    {
      "name": "package_definition_id",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the Quickstart transformation package definition within the Fivetran system",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "id",
              "name",
              "version"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier for the Quickstart transformation package definition within the Fivetran system"
              },
              "name": {
                "type": "string",
                "description": "The Quickstart transformation package name"
              },
              "version": {
                "type": "string",
                "description": "The Quickstart package definition version"
              },
              "connector_types": {
                "uniqueItems": true,
                "type": "array",
                "description": "The set of connector types",
                "items": {
                  "type": "string"
                }
              },
              "output_model_names": {
                "type": "array",
                "description": "The list of transformation output models",
                "items": {
                  "type": "string"
                }
              },
              "configurable_variables": {
                "type": "object",
                "description": "The map of configurable variable values keyed by variable name."
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}