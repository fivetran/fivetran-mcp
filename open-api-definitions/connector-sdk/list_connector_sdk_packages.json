{
  "description": "⚠️ RESULTS ARE PAGINATED. Returns a list of all Connector SDK packages in your Fivetran account.",
  "path": "/v1/connector-sdk/packages",
  "method": "GET",
  "parameters": [
    {
      "name": "cursor",
      "in": "query",
      "required": false,
      "description": "Paging cursor, [read more about pagination](https://fivetran.com/docs/rest-api/pagination)",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "description": "Number of records to fetch per page. Accepts a number in the range 1..1000; the default value is 100.",
      "schema": {
        "type": "integer",
        "format": "int32"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "description": "The collection of returned items",
                "items": {
                  "required": [
                    "created_at",
                    "created_by",
                    "id",
                    "last_updated_by",
                    "updated_at"
                  ],
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "The unique identifier for the Connector SDK package."
                    },
                    "connection_id": {
                      "type": "string",
                      "description": "The connection identifier associated with this package. Each package can only be associated with one connection at a time. Returns null if the package is not yet associated with any connection."
                    },
                    "created_by": {
                      "type": "string",
                      "description": "The unique identifier of the user who created the package."
                    },
                    "last_updated_by": {
                      "type": "string",
                      "description": "The unique identifier of the user who last updated the package."
                    },
                    "created_at": {
                      "type": "string",
                      "description": "The timestamp when the package was created.",
                      "format": "date-time"
                    },
                    "updated_at": {
                      "type": "string",
                      "description": "The timestamp when the package was last updated.",
                      "format": "date-time"
                    },
                    "file_sha256_hash": {
                      "type": "string",
                      "description": "The SHA-256 hash of the uploaded package file. Used for integrity verification and change detection."
                    }
                  }
                }
              },
              "next_cursor": {
                "type": "string",
                "description": "The value of the cursor parameter for the next page"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}