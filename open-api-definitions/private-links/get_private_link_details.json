{
  "description": "Returns a private link object if a valid identifier was provided.",
  "path": "/v1/private-links/{privateLinkId}",
  "method": "GET",
  "parameters": [
    {
      "name": "privateLinkId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the private link within the Fivetran system",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "cloud_provider",
              "config",
              "created_at",
              "created_by",
              "id",
              "name",
              "region",
              "service",
              "state",
              "state_summary"
            ],
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "The unique identifier for the private link within the Fivetran system."
              },
              "name": {
                "type": "string",
                "description": "Private link name"
              },
              "region": {
                "type": "string",
                "description": "Data processing location. This is where Fivetran will operate and run computation on data.",
                "enum": [
                  "GCP_US_EAST4",
                  "GCP_US_WEST1",
                  "GCP_EUROPE_WEST3",
                  "GCP_AUSTRALIA_SOUTHEAST1",
                  "GCP_NORTHAMERICA_NORTHEAST1",
                  "GCP_EUROPE_WEST2",
                  "GCP_ASIA_SOUTHEAST1",
                  "GCP_ASIA_SOUTHEAST2",
                  "GCP_ASIA_SOUTH1",
                  "GCP_ASIA_NORTHEAST1",
                  "AWS_US_EAST_1",
                  "AWS_US_EAST_2",
                  "AWS_US_WEST_2",
                  "AWS_AP_NORTHEAST_1",
                  "AWS_AP_SOUTHEAST_1",
                  "AWS_AP_SOUTHEAST_2",
                  "AWS_EU_CENTRAL_1",
                  "AWS_EU_WEST_1",
                  "AWS_EU_WEST_2",
                  "AWS_AP_SOUTH_1",
                  "AWS_CA_CENTRAL_1",
                  "AWS_US_GOV_WEST_1",
                  "AZURE_EASTUS2",
                  "AZURE_AUSTRALIAEAST",
                  "AZURE_UKSOUTH",
                  "AZURE_WESTEUROPE",
                  "AZURE_CENTRALUS",
                  "AZURE_CANADACENTRAL",
                  "AZURE_UAENORTH",
                  "AZURE_SOUTHEASTASIA"
                ]
              },
              "service": {
                "type": "string",
                "description": "The name for the service type within the Fivetran system.",
                "enum": [
                  "DATABRICKS_AWS",
                  "SNOWFLAKE_AWS",
                  "REDSHIFT_AWS",
                  "SOURCE_AWS",
                  "DATABRICKS_AZURE",
                  "SNOWFLAKE_AZURE",
                  "ONELAKE_AZURE",
                  "POSTGRES_WAREHOUSE_AZURE",
                  "SQL_DATA_WAREHOUSE_AZURE",
                  "SOURCE_AZURE",
                  "SNOWFLAKE_GCP",
                  "SOURCE_GCP",
                  "DATABRICKS_GCP"
                ]
              },
              "state": {
                "type": "string",
                "description": "Private link state",
                "enum": [
                  "CREATING",
                  "UPDATING",
                  "DESTROYING",
                  "OK",
                  "FAIL"
                ]
              },
              "host": {
                "type": "string",
                "description": "The DNS name of the PrivateLink endpoint service."
              },
              "account_id": {
                "type": "string"
              },
              "cloud_provider": {
                "type": "string",
                "description": "Private link cloud provider",
                "enum": [
                  "AWS",
                  "GCP",
                  "AZURE"
                ]
              },
              "created_at": {
                "type": "string",
                "description": "The timestamp of the time the private link was created in your account",
                "format": "date-time"
              },
              "created_by": {
                "type": "string",
                "description": "The actor who created the private link"
              },
              "state_summary": {
                "type": "string",
                "description": "Private link state summary"
              },
              "resource_upstream_status": {
                "type": "string",
                "description": "The upstream status of the PrivateLink resource as reported by the cloud provider."
              }
            },
            "discriminator": {
              "propertyName": "service",
              "mapping": {
                "DATABRICKS_AWS": "#/components/schemas/databricks_aws_PrivateLinkResponse",
                "SNOWFLAKE_AWS": "#/components/schemas/snowflake_aws_PrivateLinkResponse",
                "REDSHIFT_AWS": "#/components/schemas/redshift_aws_PrivateLinkResponse",
                "SOURCE_AWS": "#/components/schemas/source_aws_PrivateLinkResponse",
                "DATABRICKS_AZURE": "#/components/schemas/databricks_azure_PrivateLinkResponse",
                "SNOWFLAKE_AZURE": "#/components/schemas/snowflake_azure_PrivateLinkResponse",
                "ONELAKE_AZURE": "#/components/schemas/onelake_azure_PrivateLinkResponse",
                "POSTGRES_WAREHOUSE_AZURE": "#/components/schemas/postgres_warehouse_azure_PrivateLinkResponse",
                "SQL_DATA_WAREHOUSE_AZURE": "#/components/schemas/sql_data_warehouse_azure_PrivateLinkResponse",
                "SOURCE_AZURE": "#/components/schemas/source_azure_PrivateLinkResponse",
                "SNOWFLAKE_GCP": "#/components/schemas/snowflake_gcp_PrivateLinkResponse",
                "SOURCE_GCP": "#/components/schemas/source_gcp_PrivateLinkResponse",
                "DATABRICKS_GCP": "#/components/schemas/databricks_gcp_PrivateLinkResponse"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}