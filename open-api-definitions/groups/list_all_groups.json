{
  "description": "⚠️ RESULTS ARE PAGINATED. Returns a list of all groups within your Fivetran account.",
  "path": "/v1/groups",
  "method": "GET",
  "parameters": [
    {
      "name": "cursor",
      "in": "query",
      "required": false,
      "description": "Paging cursor, [read more about pagination](https://fivetran.com/docs/rest-api/pagination)",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "limit",
      "in": "query",
      "required": false,
      "description": "Number of records to fetch per page. Accepts a number in the range 1..1000; the default value is 100.",
      "schema": {
        "type": "integer",
        "format": "int32"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "description": "The collection of returned items",
                "items": {
                  "required": [
                    "created_at",
                    "id",
                    "name"
                  ],
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "The unique identifier for the group within the Fivetran system."
                    },
                    "name": {
                      "type": "string",
                      "description": "The name of the group within your account."
                    },
                    "created_at": {
                      "type": "string",
                      "description": "The timestamp of when the group was created in your account.",
                      "format": "date-time"
                    }
                  }
                }
              },
              "next_cursor": {
                "type": "string",
                "description": "The value of the cursor parameter for the next page"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}