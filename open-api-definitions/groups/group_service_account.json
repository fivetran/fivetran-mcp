{
  "description": "Returns Fivetran service account associated with the group.",
  "path": "/v1/groups/{groupId}/service-account",
  "method": "GET",
  "parameters": [
    {
      "name": "groupId",
      "in": "path",
      "required": true,
      "description": "The unique identifier for the group within the Fivetran system.",
      "schema": {
        "type": "string"
      }
    }
  ],
  "response": {
    "content": {
      "application/json": {
        "required": [
          "code",
          "data"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Response status code"
          },
          "message": {
            "type": "string",
            "description": "Response status text"
          },
          "data": {
            "required": [
              "service_account"
            ],
            "type": "object",
            "properties": {
              "service_account": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "description": "Successful response"
  }
}